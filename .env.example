# Copy this file to .env on the server and fill in the values.
# .env is git-ignored and never committed.

# --- WireGuard proxy ports ---
SERVER_PORT=51820
CLIENT_PORT=51821
SESSION_TIMEOUT=300
LOG_LEVEL=INFO

# --- Connection gating via Pushover (optional) ---
# Leave empty to disable gating.
# Get your tokens at https://pushover.net
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Public base URL of this host (no trailing slash).
# The allow-link will be: GATE_PUBLIC_URL:GATE_HTTP_PORT/allow?token=...
GATE_PUBLIC_URL=http://your-server.example.com
GATE_HTTP_PORT=9999

# How long (seconds) an unclicked allow-link stays valid.
GATE_TOKEN_TTL=600
